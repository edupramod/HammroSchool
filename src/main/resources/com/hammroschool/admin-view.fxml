<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane style="-fx-background-color: #f8fafc;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.hammroschool.controller.AdminController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: #0f172a; -fx-padding: 18 28;">
            <children>
                <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="Hammro School -Admin Dashboard" />
                <Label fx:id="welcomeLabel" style="-fx-text-fill: #cbd5e1; -fx-font-size: 14px;" />
            </children>
        </HBox>
    </top>

    <center>
        <HBox spacing="24" style="-fx-padding: 28;">
            <children>
                <VBox prefWidth="360" spacing="14" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 22; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.12), 20, 0.2, 0, 8);">
                    <children>
                        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Create account" />
                        <TextField fx:id="usernameField" prefHeight="40" promptText="Username" />
                        <PasswordField fx:id="passwordField" prefHeight="40" promptText="Password" />
                        <ChoiceBox fx:id="roleChoiceBox" prefHeight="40" />
                        <Button onAction="#handleCreateAccount" prefHeight="42" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" text="Create Account" />
                        <Label fx:id="statusLabel" style="-fx-text-fill: #475569;" wrapText="true" />
                        <Separator />
                        <Button onAction="#handleLogout" prefHeight="40" style="-fx-background-color: #e2e8f0; -fx-text-fill: #0f172a; -fx-font-weight: bold; -fx-background-radius: 10;" text="Logout" />
                    </children>
                </VBox>

                <VBox spacing="14" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 22; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.12), 20, 0.2, 0, 8);" VBox.vgrow="ALWAYS">
                    <children>
                        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Registered accounts" />
                        <ListView fx:id="accountListView" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>
            </children>
        </HBox>
    </center>
</BorderPane>
