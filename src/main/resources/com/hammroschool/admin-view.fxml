<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="860.0" prefWidth="1280.0" style="-fx-background-color: #f8f8f7; -fx-font-family: 'Segoe UI';" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hammroschool.controller.AdminController">
    <left>
        <VBox prefWidth="216.0" spacing="18.0" style="-fx-background-color: #fbfbfa; -fx-border-color: #eceae6; -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets bottom="24.0" left="20.0" right="16.0" top="18.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <ImageView fitHeight="38.0" fitWidth="38.0" preserveRatio="true">
                            <image>
                                <Image url="@images/logo.png" />
                            </image>
                        </ImageView>
                        <VBox spacing="2.0">
                            <children>
                                <Label style="-fx-text-fill: #161616; -fx-font-size: 16px; -fx-font-weight: 800;" text="Hammro School" />
                                <Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 12px;" text="Admin Portal" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="10.0">
                    <children>
                        <Button alignment="CENTER_LEFT" graphicTextGap="12.0" prefHeight="28.0" style="-fx-background-color: #111111; -fx-background-radius: 8; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 700; -fx-padding: 10 14 10 14;" text="Dashboard">
                            <graphic>
                                <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                    <image>
                                        <Image url="@images/admin-dashboard/dashboard-icon.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>
                        <Button alignment="CENTER_LEFT" graphicTextGap="12.0" prefHeight="28.0" style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14;" text="Accounts">
                            <graphic>
                                <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                    <image>
                                        <Image url="@images/admin-dashboard/account-icon.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>
                        <Button alignment="CENTER_LEFT" graphicTextGap="12.0" prefHeight="28.0" style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14;" text="Teachers">
                            <graphic>
                                <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                    <image>
                                        <Image url="@images/admin-dashboard/teachers-icon.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>
                        <Button alignment="CENTER_LEFT" graphicTextGap="12.0" prefHeight="28.0" style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14;" text="Students">
                            <graphic>
                                <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                    <image>
                                        <Image url="@images/admin-dashboard/student-icon.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>
                        <Button alignment="CENTER_LEFT" graphicTextGap="12.0" prefHeight="28.0" style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14;" text="Settings">
                            <graphic>
                                <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                    <image>
                                        <Image url="@images/admin-dashboard/settings-icon.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>
                    </children>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <Button alignment="CENTER_LEFT" graphicTextGap="12.0" onAction="#handleLogout" prefHeight="40.0" style="-fx-background-color: transparent; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14;" text="Logout">
                    <graphic>
                        <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                            <image>
                                <Image url="@images/admin-dashboard/logout-icon.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>
            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" pannable="true" style="-fx-background: transparent; -fx-background-color: transparent;">
            <content>
                <VBox spacing="22.0" style="-fx-padding: 24 28 28 28; -fx-background-color: transparent;">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="16.0">
                            <children>
                                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-font-size: 28px; -fx-font-weight: 800; -fx-text-fill: #171717;" text="Admin Dashboard" />
                                        <Label fx:id="welcomeLabel" style="-fx-font-size: 14px; -fx-text-fill: #8a8a8a;" text="Welcome back, manage accounts and view activity" />
                                    </children>
                                </VBox>

                                <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 999; -fx-border-color: #ebe9e4; -fx-border-radius: 999; -fx-padding: 8 14 8 10;">
                                    <children>
                                        <Label style="-fx-background-color: #1d1d1d; -fx-background-radius: 999; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: 800; -fx-min-width: 28; -fx-min-height: 28; -fx-pref-width: 28; -fx-pref-height: 28; -fx-alignment: center;" text="AD" />
                                        <Label style="-fx-text-fill: #1f1f1f; -fx-font-size: 13px; -fx-font-weight: 700;" text="admin" />
                                    </children>
                                </HBox>
                            </children>
                        </HBox>

                        <HBox spacing="18.0">
                            <children>
                                <VBox prefWidth="210.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e8e6e1; -fx-border-radius: 14; -fx-padding: 18 18 18 18; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.08), 16, 0.14, 0, 4);">
                                    <children>
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 13px;" text="Total Accounts" />
                                                        <Label fx:id="totalAccountsLabel" style="-fx-text-fill: #171717; -fx-font-size: 28px; -fx-font-weight: 800;" text="128" />
                                                    </children>
                                                </VBox>
                                                <StackPane style="-fx-background-color: #f4f4f3; -fx-background-radius: 12; -fx-min-width: 36; -fx-min-height: 36; -fx-pref-width: 36; -fx-pref-height: 36;">
                                                    <children>
                                                        <ImageView fitHeight="18.0" fitWidth="18.0" preserveRatio="true">
                                                            <image>
                                                                <Image url="@images/admin-dashboard/total-account-icon.png" />
                                                            </image>
                                                        </ImageView>
                                                    </children>
                                                </StackPane>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox prefWidth="210.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e8e6e1; -fx-border-radius: 14; -fx-padding: 18 18 18 18; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.08), 16, 0.14, 0, 4);">
                                    <children>
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 13px;" text="Teachers" />
                                                        <Label fx:id="teacherCountLabel" style="-fx-text-fill: #171717; -fx-font-size: 28px; -fx-font-weight: 800;" text="42" />
                                                    </children>
                                                </VBox>
                                                <StackPane style="-fx-background-color: #f4f4f3; -fx-background-radius: 12; -fx-min-width: 36; -fx-min-height: 36; -fx-pref-width: 36; -fx-pref-height: 36;">
                                                    <children>
                                                        <ImageView fitHeight="18.0" fitWidth="18.0" preserveRatio="true">
                                                            <image>
                                                                <Image url="@images/admin-dashboard/teachers-icon.png" />
                                                            </image>
                                                        </ImageView>
                                                    </children>
                                                </StackPane>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox prefWidth="210.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e8e6e1; -fx-border-radius: 14; -fx-padding: 18 18 18 18; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.08), 16, 0.14, 0, 4);">
                                    <children>
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 13px;" text="Students" />
                                                        <Label fx:id="studentCountLabel" style="-fx-text-fill: #171717; -fx-font-size: 28px; -fx-font-weight: 800;" text="86" />
                                                    </children>
                                                </VBox>
                                                <StackPane style="-fx-background-color: #f4f4f3; -fx-background-radius: 12; -fx-min-width: 36; -fx-min-height: 36; -fx-pref-width: 36; -fx-pref-height: 36;">
                                                    <children>
                                                        <ImageView fitHeight="18.0" fitWidth="18.0" preserveRatio="true">
                                                            <image>
                                                                <Image url="@images/admin-dashboard/student-icon.png" />
                                                            </image>
                                                        </ImageView>
                                                    </children>
                                                </StackPane>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox spacing="18.0" VBox.vgrow="ALWAYS">
                            <children>
                                <VBox prefWidth="330.0" spacing="18.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #e8e6e1; -fx-border-radius: 16; -fx-padding: 22; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.08), 18, 0.14, 0, 4);">
                                    <children>
                                        <VBox spacing="4.0">
                                            <children>
                                                <Label style="-fx-font-size: 20px; -fx-font-weight: 800; -fx-text-fill: #171717;" text="Create Account" />
                                                <Label style="-fx-font-size: 13px; -fx-text-fill: #8a8a8a;" text="Add a new user to the system" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="8.0">
                                            <children>
                                                <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #222222;" text="Username" />
                                                <TextField fx:id="usernameField" prefHeight="40.0" promptText="Enter username" style="-fx-background-color: #fbfbfa; -fx-background-radius: 10; -fx-border-color: #e6e4df; -fx-border-radius: 10; -fx-padding: 0 12 0 12; -fx-font-size: 13px; -fx-text-fill: #222222; -fx-prompt-text-fill: #a0a0a0;" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="8.0">
                                            <children>
                                                <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #222222;" text="Password" />
                                                <PasswordField fx:id="passwordField" prefHeight="40.0" promptText="Enter password" style="-fx-background-color: #fbfbfa; -fx-background-radius: 10; -fx-border-color: #e6e4df; -fx-border-radius: 10; -fx-padding: 0 12 0 12; -fx-font-size: 13px; -fx-text-fill: #222222; -fx-prompt-text-fill: #a0a0a0;" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="8.0">
                                            <children>
                                                <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #222222;" text="Role" />
                                                <ChoiceBox fx:id="roleChoiceBox" prefHeight="40.0" style="-fx-background-color: #fbfbfa; -fx-background-radius: 10; -fx-border-color: #e6e4df; -fx-border-radius: 10; -fx-padding: 4 8 4 8;" />
                                            </children>
                                        </VBox>

                                        <Button onAction="#handleCreateAccount" prefHeight="42.0" style="-fx-background-color: #171717; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 700; -fx-padding: 0 16 0 16; -fx-cursor: hand;" text="Create Account">
                                            <graphic>
                                                <ImageView fitHeight="14.0" fitWidth="14.0" preserveRatio="true">
                                                    <image>
                                                        <Image url="@images/admin-dashboard/create-account-icon.png" />
                                                    </image>
                                                </ImageView>
                                            </graphic>
                                        </Button>

                                        <Label fx:id="statusLabel" style="-fx-text-fill: #6b7280; -fx-font-size: 12px; -fx-font-weight: 600;" wrapText="true" />
                                    </children>
                                </VBox>

                                <VBox spacing="16.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #e8e6e1; -fx-border-radius: 16; -fx-padding: 22; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.08), 18, 0.14, 0, 4);" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="14.0">
                                            <children>
                                                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label style="-fx-font-size: 20px; -fx-font-weight: 800; -fx-text-fill: #171717;" text="Registered Accounts" />
                                                        <Label style="-fx-font-size: 13px; -fx-text-fill: #8a8a8a;" text="All active users in the platform" />
                                                    </children>
                                                </VBox>

                                                <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #fbfbfa; -fx-background-radius: 10; -fx-border-color: #e6e4df; -fx-border-radius: 10; -fx-padding: 0 12 0 10;">
                                                    <children>
                                                        <ImageView fitHeight="14.0" fitWidth="14.0" preserveRatio="true">
                                                            <image>
                                                                <Image url="@images/admin-dashboard/search-icon.png" />
                                                            </image>
                                                        </ImageView>
                                                        <TextField fx:id="searchField" prefHeight="36.0" promptText="Search" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-focus-color: transparent; -fx-faint-focus-color: transparent; -fx-font-size: 13px; -fx-text-fill: #222222; -fx-prompt-text-fill: #a0a0a0;" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </HBox>

                                        <TableView fx:id="accountTable" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="userColumn" prefWidth="200.0" text="User" />
                                                <TableColumn fx:id="usernameColumn" prefWidth="140.0" text="Username" />
                                                <TableColumn fx:id="roleColumn" prefWidth="120.0" text="Role" />
                                                <TableColumn fx:id="actionsColumn" prefWidth="90.0" text="Actions" />
                                            </columns>
                                        </TableView>

                                        <HBox alignment="CENTER_LEFT" spacing="14.0">
                                            <children>
                                                <Label fx:id="summaryLabel" style="-fx-text-fill: #8a8a8a; -fx-font-size: 13px;" text="Showing 5 of 128 accounts" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <HBox spacing="8.0">
                                                    <children>
                                                        <Button style="-fx-background-color: #fbfbfa; -fx-border-color: #e6e4df; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #6b7280; -fx-font-size: 12px; -fx-font-weight: 600; -fx-padding: 8 12 8 12;" text="Previous" />
                                                        <Button style="-fx-background-color: #fbfbfa; -fx-border-color: #e6e4df; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #6b7280; -fx-font-size: 12px; -fx-font-weight: 600; -fx-padding: 8 12 8 12;" text="Next" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
