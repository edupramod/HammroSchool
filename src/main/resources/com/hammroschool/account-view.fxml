<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="860.0" prefWidth="1280.0" stylesheets="@styles.css" style="-fx-background-color: #f8f8f7; -fx-font-family: 'Segoe UI';" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hammroschool.controller.AccountController">

    <!-- ═══════════════════════════════════════════════════════ SIDEBAR ══ -->
    <left>
        <VBox prefWidth="216.0" spacing="18.0" style="-fx-background-color: #fbfbfa; -fx-border-color: #eceae6; -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets bottom="24.0" left="20.0" right="16.0" top="18.0" />
            </padding>
            <children>

                <!-- Logo + App name -->
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <ImageView fitHeight="38.0" fitWidth="38.0" preserveRatio="true">
                            <image>
                                <Image url="@images/logo.png" />
                            </image>
                        </ImageView>
                        <VBox spacing="2.0">
                            <children>
                                <Label style="-fx-text-fill: #161616; -fx-font-size: 16px; -fx-font-weight: 800;" text="Hammro School" />
                                <Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 12px;" text="Admin Portal" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- Nav buttons -->
                <VBox spacing="4.0">
                    <children>
                        <Button alignment="CENTER_LEFT" graphicTextGap="12.0" onAction="#handleNavDashboard" prefHeight="40.0" maxWidth="1.7976931348623157E308"
                                style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14; -fx-cursor: hand;" text="Dashboard">
                            <graphic>
                                <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                    <image>
                                        <Image url="@images/account-dashboard/dashboard-icon.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>

                        <!-- ACTIVE: Accounts -->
                        <Button alignment="CENTER_LEFT" graphicTextGap="12.0" prefHeight="40.0" maxWidth="1.7976931348623157E308"
                                style="-fx-background-color: #111111; -fx-background-radius: 8; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 700; -fx-padding: 10 14 10 14; -fx-cursor: hand;" text="Accounts">
                            <graphic>
                                <ImageView fx:id="accountsNavIcon" fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                    <image>
                                        <Image url="@images/account-dashboard/account-icon.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>

                        <Button alignment="CENTER_LEFT" graphicTextGap="12.0" prefHeight="40.0" maxWidth="1.7976931348623157E308"
                                style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14; -fx-cursor: hand;" text="Teachers">
                            <graphic>
                                <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                    <image>
                                        <Image url="@images/account-dashboard/teachers-icon.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>

                        <Button alignment="CENTER_LEFT" graphicTextGap="12.0" prefHeight="40.0" maxWidth="1.7976931348623157E308"
                                style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14; -fx-cursor: hand;" text="Students">
                            <graphic>
                                <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                    <image>
                                        <Image url="@images/account-dashboard/student-icon.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>

                        <Button alignment="CENTER_LEFT" graphicTextGap="12.0" prefHeight="40.0" maxWidth="1.7976931348623157E308"
                                style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14; -fx-cursor: hand;" text="Settings">
                            <graphic>
                                <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                    <image>
                                        <Image url="@images/account-dashboard/settings-icon.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>
                    </children>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <!-- Logout -->
                <Button fx:id="logoutButton" alignment="CENTER_LEFT" graphicTextGap="12.0" onAction="#handleLogout"
                        prefHeight="40.0" maxWidth="1.7976931348623157E308"
                        style="-fx-background-color: transparent; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14; -fx-cursor: hand;" text="Logout">
                    <graphic>
                        <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                            <image>
                                <Image url="@images/account-dashboard/logout-icon.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

            </children>
        </VBox>
    </left>

    <!-- ════════════════════════════════════════════════════ MAIN CONTENT ══ -->
    <center>
        <VBox spacing="0.0" style="-fx-background-color: #f8f8f7;">

            <!-- Top header bar -->
            <HBox alignment="CENTER_LEFT" spacing="16.0"
                  style="-fx-background-color: #f8f8f7; -fx-border-color: #eceae6; -fx-border-width: 0 0 1 0; -fx-padding: 18 28 18 28;">
                <children>
                    <!-- Page title -->
                    <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                        <children>
                            <Label style="-fx-font-size: 26px; -fx-font-weight: 800; -fx-text-fill: #171717;" text="Accounts" />
                            <Label style="-fx-font-size: 13px; -fx-text-fill: #8a8a8a;" text="Manage all registered accounts" />
                        </children>
                    </VBox>

                    <!-- Alerts button -->
                    <HBox alignment="CENTER" spacing="8.0"
                          style="-fx-background-color: white; -fx-background-radius: 999; -fx-border-color: #e8e6e1; -fx-border-radius: 999; -fx-padding: 8 16 8 12; -fx-cursor: hand;">
                        <children>
                            <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                <image>
                                    <Image url="@images/account-dashboard/alerts-btn-icon.png" />
                                </image>
                            </ImageView>
                            <Label style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333333;" text="Alerts" />
                        </children>
                    </HBox>

                    <!-- User badge -->
                    <HBox alignment="CENTER_LEFT" spacing="10.0"
                          style="-fx-background-color: white; -fx-background-radius: 999; -fx-border-color: #e8e6e1; -fx-border-radius: 999; -fx-padding: 8 14 8 10;">
                        <children>
                            <Label fx:id="userInitialsLabel"
                                   style="-fx-background-color: #1d1d1d; -fx-background-radius: 999; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: 800; -fx-min-width: 28; -fx-min-height: 28; -fx-pref-width: 28; -fx-pref-height: 28; -fx-alignment: center;"
                                   text="AD" />
                            <Label fx:id="userNameLabel"
                                   style="-fx-text-fill: #1f1f1f; -fx-font-size: 13px; -fx-font-weight: 700;"
                                   text="admin" />
                        </children>
                    </HBox>
                </children>
            </HBox>

            <!-- Accounts table card -->
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" pannable="false"
                        style="-fx-background: transparent; -fx-background-color: transparent;"
                        VBox.vgrow="ALWAYS">
                <content>
                    <VBox style="-fx-padding: 24 28 28 28; -fx-background-color: transparent;">
                        <children>

                            <!-- Card -->
                            <VBox spacing="16.0"
                                  style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #e8e6e1; -fx-border-radius: 16; -fx-padding: 22; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.08), 18, 0.14, 0, 4);">
                                <children>

                                    <!-- Card header: title + search -->
                                    <HBox alignment="CENTER_LEFT" spacing="14.0">
                                        <children>
                                            <Label style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #171717;" text="All Accounts" HBox.hgrow="ALWAYS" />
                                            <Region HBox.hgrow="ALWAYS" />

                                            <!-- Search box -->
                                            <HBox alignment="CENTER_LEFT" spacing="8.0"
                                                  style="-fx-background-color: #f8f8f7; -fx-background-radius: 10; -fx-border-color: #e6e4df; -fx-border-radius: 10; -fx-padding: 0 12 0 10; -fx-min-width: 220; -fx-pref-width: 260;">
                                                <children>
                                                    <ImageView fitHeight="14.0" fitWidth="14.0" preserveRatio="true">
                                                        <image>
                                                            <Image url="@images/account-dashboard/search-icon.png" />
                                                        </image>
                                                    </ImageView>
                                                    <TextField fx:id="searchField" prefHeight="36.0"
                                                               promptText="Search"
                                                               style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-focus-color: transparent; -fx-faint-focus-color: transparent; -fx-font-size: 13px; -fx-text-fill: #222222; -fx-prompt-text-fill: #a0a0a0;"
                                                               HBox.hgrow="ALWAYS" />
                                                </children>
                                            </HBox>
                                        </children>
                                    </HBox>

                                    <!-- Table -->
                                    <TableView fx:id="accountTable" prefHeight="440.0" VBox.vgrow="ALWAYS">
                                        <columns>
                                            <TableColumn fx:id="userColumn"    prefWidth="260.0" text="User" />
                                            <TableColumn fx:id="usernameColumn" prefWidth="200.0" text="Username" />
                                            <TableColumn fx:id="roleColumn"    prefWidth="180.0" text="Role" />
                                            <TableColumn fx:id="actionsColumn" prefWidth="100.0" text="Actions" />
                                        </columns>
                                    </TableView>

                                    <!-- Footer: summary + pagination -->
                                    <HBox alignment="CENTER_LEFT" spacing="14.0">
                                        <children>
                                            <Label fx:id="summaryLabel"
                                                   style="-fx-text-fill: #8a8a8a; -fx-font-size: 13px;"
                                                   text="Showing 0 accounts" />
                                            <Region HBox.hgrow="ALWAYS" />
                                            <HBox spacing="8.0">
                                                <children>
                                                    <Button fx:id="prevButton" onAction="#handlePrevPage"
                                                            style="-fx-background-color: white; -fx-border-color: #e6e4df; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #333333; -fx-font-size: 12px; -fx-font-weight: 600; -fx-padding: 8 16 8 16; -fx-cursor: hand;"
                                                            text="Previous" />
                                                    <Button fx:id="nextButton" onAction="#handleNextPage"
                                                            style="-fx-background-color: white; -fx-border-color: #e6e4df; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #333333; -fx-font-size: 12px; -fx-font-weight: 600; -fx-padding: 8 16 8 16; -fx-cursor: hand;"
                                                            text="Next" />
                                                </children>
                                            </HBox>
                                        </children>
                                    </HBox>

                                </children>
                            </VBox>

                        </children>
                    </VBox>
                </content>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>
