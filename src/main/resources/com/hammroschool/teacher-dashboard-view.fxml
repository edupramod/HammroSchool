<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="860.0" prefWidth="1280.0" stylesheets="@styles.css"
            style="-fx-background-color: #f8f8f7; -fx-font-family: 'Segoe UI';"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hammroschool.controller.TeacherDashboardController">

    <!-- ═══ SIDEBAR ═══ -->
    <left>
        <VBox prefWidth="220.0" spacing="18.0"
              style="-fx-background-color: #fbfbfa; -fx-border-color: #eceae6; -fx-border-width: 0 1 0 0;">
            <padding><Insets bottom="24.0" left="20.0" right="16.0" top="18.0" /></padding>
            <children>

                <!-- Logo -->
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <ImageView fitHeight="38.0" fitWidth="38.0" preserveRatio="true">
                            <image><Image url="@assets/logo.png" /></image>
                        </ImageView>
                        <VBox spacing="2.0">
                            <children>
                                <Label style="-fx-text-fill: #161616; -fx-font-size: 16px; -fx-font-weight: 800;" text="Hammro School" />
                                <Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 12px;" text="Teacher Portal" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- Nav -->
                <VBox spacing="8.0">
                    <children>
                        <Button fx:id="navDashboardBtn" alignment="CENTER_LEFT" graphicTextGap="12.0"
                                onAction="#handleNavDashboard" prefHeight="40.0" maxWidth="Infinity"
                                style="-fx-background-color: #111111; -fx-background-radius: 8; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 700; -fx-padding: 10 14 10 14; -fx-cursor: hand;"
                                text="Dashboard">
                            <graphic><ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                <image><Image url="@assets/admin/aside/dashboard.png" /></image>
                            </ImageView></graphic>
                        </Button>

                        <Button fx:id="navMarkSheetBtn" alignment="CENTER_LEFT" graphicTextGap="12.0"
                                onAction="#handleNavMarkSheet" prefHeight="40.0" maxWidth="Infinity"
                                style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14; -fx-cursor: hand;"
                                text="Mark Sheet">
                            <graphic><ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                <image><Image url="@assets/admin/aside/student.png" /></image>
                            </ImageView></graphic>
                        </Button>

                        <Button fx:id="navReportCardBtn" alignment="CENTER_LEFT" graphicTextGap="12.0"
                                onAction="#handleNavReportCard" prefHeight="40.0" maxWidth="Infinity"
                                style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14; -fx-cursor: hand;"
                                text="Report Card">
                            <graphic><ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                <image><Image url="@assets/admin/aside/account.png" /></image>
                            </ImageView></graphic>
                        </Button>

                        <Button fx:id="navPerformanceBtn" alignment="CENTER_LEFT" graphicTextGap="12.0"
                                onAction="#handleNavPerformance" prefHeight="40.0" maxWidth="Infinity"
                                style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14; -fx-cursor: hand;"
                                text="Performance">
                            <graphic><ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                <image><Image url="@assets/admin/aside/dashboard-dark.png" /></image>
                            </ImageView></graphic>
                        </Button>
                    </children>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <Button fx:id="logoutButton" alignment="CENTER_LEFT" graphicTextGap="12.0"
                        onAction="#handleLogout" prefHeight="40.0" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14; -fx-cursor: hand;"
                        text="Logout">
                    <graphic><ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                        <image><Image url="@assets/admin/aside/logout.png" /></image>
                    </ImageView></graphic>
                </Button>
            </children>
        </VBox>
    </left>

    <!-- ═══ MAIN CONTENT ═══ -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <content>
                <VBox spacing="20.0" style="-fx-padding: 24 28 28 28; -fx-background-color: transparent;">
                    <children>

                        <!-- Top bar -->
                        <HBox alignment="CENTER_LEFT" spacing="16.0">
                            <children>
                                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="pageTitle"
                                               style="-fx-font-size: 28px; -fx-font-weight: 800; -fx-text-fill: #171717;"
                                               text="Dashboard" />
                                        <Label fx:id="pageSubtitle"
                                               style="-fx-font-size: 14px; -fx-text-fill: #8a8a8a;"
                                               text="Welcome to your teacher portal" />
                                    </children>
                                </VBox>
                                <HBox alignment="CENTER_LEFT" spacing="10.0"
                                      style="-fx-background-color: white; -fx-background-radius: 999; -fx-border-color: #ebe9e4; -fx-border-radius: 999; -fx-padding: 8 14 8 10;">
                                    <children>
                                        <Label fx:id="userInitialsLabel"
                                               style="-fx-background-color: #1d1d1d; -fx-background-radius: 999; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: 800; -fx-min-width: 28; -fx-min-height: 28; -fx-pref-width: 28; -fx-pref-height: 28; -fx-alignment: center;"
                                               text="TC" />
                                        <Label fx:id="userNameLabel"
                                               style="-fx-text-fill: #1f1f1f; -fx-font-size: 13px; -fx-font-weight: 700;"
                                               text="teacher" />
                                    </children>
                                </HBox>
                            </children>
                        </HBox>

                        <Separator style="-fx-opacity: 0.5;" />

                        <!-- StackPane — controller flips visibility -->
                        <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS">
                            <children>

                                <!-- ── DASHBOARD HOME ── -->
                                <VBox fx:id="dashboardPane" spacing="18.0">
                                    <children>
                                        <!-- Stat cards -->
                                        <HBox spacing="18.0">
                                            <children>
                                                <VBox prefWidth="200.0" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e8e6e1; -fx-border-radius: 14; -fx-padding: 18; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.07), 14, 0.12, 0, 3);">
                                                    <children>
                                                        <Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 13px;" text="Total Students" />
                                                        <Label fx:id="statStudentsLabel" style="-fx-text-fill: #171717; -fx-font-size: 30px; -fx-font-weight: 800;" text="0" />
                                                    </children>
                                                </VBox>
                                                <VBox prefWidth="200.0" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e8e6e1; -fx-border-radius: 14; -fx-padding: 18; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.07), 14, 0.12, 0, 3);">
                                                    <children>
                                                        <Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 13px;" text="Marks Entered" />
                                                        <Label fx:id="statMarksLabel" style="-fx-text-fill: #171717; -fx-font-size: 30px; -fx-font-weight: 800;" text="0" />
                                                    </children>
                                                </VBox>
                                                <VBox prefWidth="200.0" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e8e6e1; -fx-border-radius: 14; -fx-padding: 18; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.07), 14, 0.12, 0, 3);">
                                                    <children>
                                                        <Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 13px;" text="Subjects" />
                                                        <Label fx:id="statSubjectsLabel" style="-fx-text-fill: #171717; -fx-font-size: 30px; -fx-font-weight: 800;" text="0" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>

                                        <!-- Recent marks table -->
                                        <VBox spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #e8e6e1; -fx-border-radius: 16; -fx-padding: 22;">
                                            <children>
                                                <Label style="-fx-font-size: 17px; -fx-font-weight: 800; -fx-text-fill: #171717;" text="Recent Marks" />
                                                <Label style="-fx-font-size: 13px; -fx-text-fill: #8a8a8a;" text="Last entries you recorded" />
                                                <TableView fx:id="recentMarksTable" prefHeight="260.0">
                                                    <columns>
                                                        <TableColumn fx:id="rmStudentCol" prefWidth="220.0" text="Student" />
                                                        <TableColumn fx:id="rmSubjectCol" prefWidth="160.0" text="Subject" />
                                                        <TableColumn fx:id="rmExamCol"    prefWidth="120.0" text="Exam" />
                                                        <TableColumn fx:id="rmScoreCol"   prefWidth="110.0" text="Score" />
                                                        <TableColumn fx:id="rmGradeCol"   prefWidth="90.0"  text="Grade" />
                                                    </columns>
                                                </TableView>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <!-- ── MARK SHEET ── -->
                                <VBox fx:id="markSheetPane" spacing="18.0" visible="false" managed="false">
                                    <children>
                                        <!-- Entry form -->
                                        <VBox spacing="16.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #e8e6e1; -fx-border-radius: 16; -fx-padding: 22;">
                                            <children>
                                                <Label style="-fx-font-size: 17px; -fx-font-weight: 800; -fx-text-fill: #171717;" text="Enter Marks" />
                                                <Label style="-fx-font-size: 13px; -fx-text-fill: #8a8a8a;" text="Record student scores for a subject and exam type" />
                                                <HBox spacing="14.0">
                                                    <children>
                                                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #222222;" text="Student" />
                                                                <ComboBox fx:id="msStudentCombo" prefHeight="38.0" maxWidth="Infinity" promptText="Select student"
                                                                          style="-fx-background-color: #fbfbfa; -fx-border-color: #e6e4df; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;" />
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #222222;" text="Subject" />
                                                                <TextField fx:id="msSubjectField" prefHeight="38.0" promptText="e.g. Mathematics"
                                                                           style="-fx-background-color: #fbfbfa; -fx-background-radius: 8; -fx-border-color: #e6e4df; -fx-border-radius: 8; -fx-padding: 0 12 0 12; -fx-font-size: 13px;" />
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #222222;" text="Exam Type" />
                                                                <ComboBox fx:id="msExamTypeCombo" prefHeight="38.0" maxWidth="Infinity"
                                                                          style="-fx-background-color: #fbfbfa; -fx-border-color: #e6e4df; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;" />
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </HBox>
                                                <HBox spacing="14.0">
                                                    <children>
                                                        <VBox spacing="6.0">
                                                            <children>
                                                                <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #222222;" text="Score" />
                                                                <TextField fx:id="msScoreField" prefHeight="38.0" prefWidth="110.0" promptText="0"
                                                                           style="-fx-background-color: #fbfbfa; -fx-background-radius: 8; -fx-border-color: #e6e4df; -fx-border-radius: 8; -fx-padding: 0 12 0 12; -fx-font-size: 13px;" />
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="6.0">
                                                            <children>
                                                                <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #222222;" text="Full Marks" />
                                                                <TextField fx:id="msFullMarksField" prefHeight="38.0" prefWidth="110.0" promptText="100"
                                                                           style="-fx-background-color: #fbfbfa; -fx-background-radius: 8; -fx-border-color: #e6e4df; -fx-border-radius: 8; -fx-padding: 0 12 0 12; -fx-font-size: 13px;" />
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #222222;" text="Remarks (optional)" />
                                                                <TextField fx:id="msRemarksField" prefHeight="38.0" promptText="e.g. Good effort"
                                                                           style="-fx-background-color: #fbfbfa; -fx-background-radius: 8; -fx-border-color: #e6e4df; -fx-border-radius: 8; -fx-padding: 0 12 0 12; -fx-font-size: 13px;" />
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </HBox>
                                                <HBox spacing="12.0" alignment="CENTER_LEFT">
                                                    <children>
                                                        <Button onAction="#handleSaveMark" prefHeight="38.0"
                                                                style="-fx-background-color: #171717; -fx-background-radius: 8; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 700; -fx-padding: 0 20 0 20; -fx-cursor: hand;"
                                                                text="Save Mark" />
                                                        <Button onAction="#handleClearMarkForm" prefHeight="38.0"
                                                                style="-fx-background-color: transparent; -fx-border-color: #e6e4df; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #555555; -fx-font-size: 13px; -fx-padding: 0 16 0 16; -fx-cursor: hand;"
                                                                text="Clear" />
                                                        <Label fx:id="msStatusLabel" style="-fx-font-size: 12px; -fx-font-weight: 600;" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>

                                        <!-- All marks table -->
                                        <VBox spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #e8e6e1; -fx-border-radius: 16; -fx-padding: 22;" VBox.vgrow="ALWAYS">
                                            <children>
                                                <HBox alignment="CENTER_LEFT" spacing="14.0">
                                                    <children>
                                                        <VBox HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label style="-fx-font-size: 17px; -fx-font-weight: 800; -fx-text-fill: #171717;" text="All Marks" />
                                                                <Label style="-fx-font-size: 13px; -fx-text-fill: #8a8a8a;" text="All marks you have recorded" />
                                                            </children>
                                                        </VBox>
                                                        <HBox alignment="CENTER_LEFT" spacing="8.0"
                                                              style="-fx-background-color: #fbfbfa; -fx-background-radius: 10; -fx-border-color: #e6e4df; -fx-border-radius: 10; -fx-padding: 0 12 0 10;">
                                                            <TextField fx:id="msSearchField" prefHeight="34.0" prefWidth="200.0"
                                                                       promptText="Search student or subject..."
                                                                       style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-focus-color: transparent; -fx-faint-focus-color: transparent; -fx-font-size: 13px;" />
                                                        </HBox>
                                                    </children>
                                                </HBox>
                                                <TableView fx:id="markSheetTable" prefHeight="300.0" VBox.vgrow="ALWAYS">
                                                    <columns>
                                                        <TableColumn fx:id="msColStudent"   prefWidth="170.0" text="Student" />
                                                        <TableColumn fx:id="msColSubject"   prefWidth="140.0" text="Subject" />
                                                        <TableColumn fx:id="msColExam"      prefWidth="110.0" text="Exam" />
                                                        <TableColumn fx:id="msColScore"     prefWidth="70.0"  text="Score" />
                                                        <TableColumn fx:id="msColFullMarks" prefWidth="90.0"  text="Full Marks" />
                                                        <TableColumn fx:id="msColGrade"     prefWidth="70.0"  text="Grade" />
                                                        <TableColumn fx:id="msColRemarks"   prefWidth="140.0" text="Remarks" />
                                                        <TableColumn fx:id="msColActions"   prefWidth="80.0"  text="Actions" />
                                                    </columns>
                                                </TableView>
                                                <Label fx:id="msSummaryLabel" style="-fx-text-fill: #8a8a8a; -fx-font-size: 13px;" text="0 records" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <!-- ── REPORT CARD ── -->
                                <VBox fx:id="reportCardPane" spacing="18.0" visible="false" managed="false">
                                    <children>
                                        <!-- Selector -->
                                        <VBox spacing="16.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #e8e6e1; -fx-border-radius: 16; -fx-padding: 22;">
                                            <children>
                                                <Label style="-fx-font-size: 17px; -fx-font-weight: 800; -fx-text-fill: #171717;" text="Report Card" />
                                                <Label style="-fx-font-size: 13px; -fx-text-fill: #8a8a8a;" text="Generate a full subject-wise academic report for a student" />
                                                <HBox spacing="14.0" alignment="CENTER_LEFT">
                                                    <children>
                                                        <VBox spacing="6.0">
                                                            <children>
                                                                <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #222222;" text="Select Student" />
                                                                <ComboBox fx:id="rcStudentCombo" prefHeight="38.0" prefWidth="260.0" promptText="Choose a student"
                                                                          style="-fx-background-color: #fbfbfa; -fx-border-color: #e6e4df; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;" />
                                                            </children>
                                                        </VBox>
                                                        <Button onAction="#handleGenerateReportCard" prefHeight="38.0"
                                                                style="-fx-background-color: #171717; -fx-background-radius: 8; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 700; -fx-padding: 0 20 0 20; -fx-cursor: hand;"
                                                                text="Generate" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>

                                        <!-- Report output -->
                                        <VBox fx:id="rcResultPane" spacing="16.0" visible="false" managed="false"
                                              style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #e8e6e1; -fx-border-radius: 16; -fx-padding: 28;">
                                            <children>
                                                <VBox spacing="4.0" style="-fx-alignment: center;">
                                                    <children>
                                                        <Label style="-fx-font-size: 22px; -fx-font-weight: 800; -fx-text-fill: #171717;" text="Hammro School" />
                                                        <Label style="-fx-font-size: 14px; -fx-text-fill: #8a8a8a;" text="Academic Report Card" />
                                                        <Separator />
                                                    </children>
                                                </VBox>
                                                <HBox spacing="28.0">
                                                    <children>
                                                        <VBox spacing="4.0">
                                                            <children>
                                                                <Label style="-fx-font-size: 12px; -fx-text-fill: #555555;" text="STUDENT" />
                                                                <Label fx:id="rcStudentName" style="-fx-font-size: 16px; -fx-font-weight: 800; -fx-text-fill: #171717;" text="—" />
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="4.0">
                                                            <children>
                                                                <Label style="-fx-font-size: 12px; -fx-text-fill: #555555;" text="TOTAL MARKS" />
                                                                <Label fx:id="rcTotalMarks" style="-fx-font-size: 16px; -fx-font-weight: 800; -fx-text-fill: #171717;" text="—" />
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="4.0">
                                                            <children>
                                                                <Label style="-fx-font-size: 12px; -fx-text-fill: #555555;" text="PERCENTAGE" />
                                                                <Label fx:id="rcPercentage" style="-fx-font-size: 16px; -fx-font-weight: 800; -fx-text-fill: #171717;" text="—" />
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="4.0">
                                                            <children>
                                                                <Label style="-fx-font-size: 12px; -fx-text-fill: #555555;" text="GRADE" />
                                                                <Label fx:id="rcGrade" style="-fx-font-size: 16px; -fx-font-weight: 800; -fx-text-fill: #171717;" text="—" />
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="4.0">
                                                            <children>
                                                                <Label style="-fx-font-size: 12px; -fx-text-fill: #555555;" text="RESULT" />
                                                                <Label fx:id="rcResult" style="-fx-font-size: 16px; -fx-font-weight: 800;" text="—" />
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </HBox>
                                                <TableView fx:id="rcTable" prefHeight="280.0">
                                                    <columns>
                                                        <TableColumn fx:id="rcColSubject"    prefWidth="200.0" text="Subject" />
                                                        <TableColumn fx:id="rcColExam"       prefWidth="120.0" text="Exam Type" />
                                                        <TableColumn fx:id="rcColScore"      prefWidth="80.0"  text="Score" />
                                                        <TableColumn fx:id="rcColFullMarks"  prefWidth="90.0"  text="Full Marks" />
                                                        <TableColumn fx:id="rcColPercentage" prefWidth="80.0"  text="Pct" />
                                                        <TableColumn fx:id="rcColGrade"      prefWidth="70.0"  text="Grade" />
                                                        <TableColumn fx:id="rcColRemarks"    prefWidth="170.0" text="Remarks" />
                                                    </columns>
                                                </TableView>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <!-- ── PERFORMANCE ── -->
                                <VBox fx:id="performancePane" spacing="18.0" visible="false" managed="false">
                                    <children>
                                        <VBox spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #e8e6e1; -fx-border-radius: 16; -fx-padding: 22;">
                                            <children>
                                                <Label style="-fx-font-size: 17px; -fx-font-weight: 800; -fx-text-fill: #171717;" text="Performance Summary" />
                                                <Label style="-fx-font-size: 13px; -fx-text-fill: #8a8a8a;" text="Class-wide results for academic decision-making" />
                                                <HBox spacing="14.0" alignment="CENTER_LEFT">
                                                    <children>
                                                        <VBox spacing="6.0">
                                                            <children>
                                                                <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #222222;" text="Filter by Subject" />
                                                                <ComboBox fx:id="pfSubjectCombo" prefHeight="38.0" prefWidth="240.0" promptText="All subjects"
                                                                          style="-fx-background-color: #fbfbfa; -fx-border-color: #e6e4df; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;" />
                                                            </children>
                                                        </VBox>
                                                        <Button onAction="#handleRefreshPerformance" prefHeight="38.0"
                                                                style="-fx-background-color: #171717; -fx-background-radius: 8; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 700; -fx-padding: 0 20 0 20; -fx-cursor: hand;"
                                                                text="Refresh" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>

                                        <!-- Stats row -->
                                        <HBox spacing="16.0">
                                            <children>
                                                <VBox prefWidth="170.0" spacing="6.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e8e6e1; -fx-border-radius: 14; -fx-padding: 16;">
                                                    <children>
                                                        <Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 12px;" text="Class Average" />
                                                        <Label fx:id="pfAvgLabel" style="-fx-font-size: 26px; -fx-font-weight: 800; -fx-text-fill: #171717;" text="—" />
                                                    </children>
                                                </VBox>
                                                <VBox prefWidth="170.0" spacing="6.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e8e6e1; -fx-border-radius: 14; -fx-padding: 16;">
                                                    <children>
                                                        <Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 12px;" text="Highest Score" />
                                                        <Label fx:id="pfHighLabel" style="-fx-font-size: 26px; -fx-font-weight: 800; -fx-text-fill: #16a34a;" text="—" />
                                                    </children>
                                                </VBox>
                                                <VBox prefWidth="170.0" spacing="6.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e8e6e1; -fx-border-radius: 14; -fx-padding: 16;">
                                                    <children>
                                                        <Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 12px;" text="Lowest Score" />
                                                        <Label fx:id="pfLowLabel" style="-fx-font-size: 26px; -fx-font-weight: 800; -fx-text-fill: #dc2626;" text="—" />
                                                    </children>
                                                </VBox>
                                                <VBox prefWidth="170.0" spacing="6.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e8e6e1; -fx-border-radius: 14; -fx-padding: 16;">
                                                    <children>
                                                        <Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 12px;" text="Pass Rate" />
                                                        <Label fx:id="pfPassLabel" style="-fx-font-size: 26px; -fx-font-weight: 800; -fx-text-fill: #171717;" text="—" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>

                                        <!-- Rankings table -->
                                        <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #e8e6e1; -fx-border-radius: 16; -fx-padding: 22;" VBox.vgrow="ALWAYS">
                                            <children>
                                                <Label style="-fx-font-size: 15px; -fx-font-weight: 800; -fx-text-fill: #171717;" text="Student Rankings" />
                                                <TableView fx:id="performanceTable" prefHeight="320.0">
                                                    <columns>
                                                        <TableColumn fx:id="pfColRank"    prefWidth="50.0"  text="#" />
                                                        <TableColumn fx:id="pfColStudent" prefWidth="190.0" text="Student" />
                                                        <TableColumn fx:id="pfColSubject" prefWidth="150.0" text="Subject" />
                                                        <TableColumn fx:id="pfColScore"   prefWidth="100.0" text="Score" />
                                                        <TableColumn fx:id="pfColPct"     prefWidth="80.0"  text="Pct" />
                                                        <TableColumn fx:id="pfColGrade"   prefWidth="80.0"  text="Grade" />
                                                        <TableColumn fx:id="pfColStatus"  prefWidth="90.0"  text="Status" />
                                                    </columns>
                                                </TableView>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                            </children>
                        </StackPane>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
