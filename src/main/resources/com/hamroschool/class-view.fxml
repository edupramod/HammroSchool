<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.hamroschool.controller.ClassController"
            style="-fx-background-color: #f5f5f4;">

    <!-- Top Bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: white; -fx-padding: 16; -fx-border-color: #e7e5e4; -fx-border-width: 0 0 1 0;">
            <Label text="Class Management" style="-fx-font-size: 20px; -fx-font-weight: 700; -fx-text-fill: #111111;"/>
            <Region HBox.hgrow="ALWAYS"/>
            
            <!-- User info -->
            <HBox alignment="CENTER" spacing="10">
                <Label fx:id="userInitialsLabel" style="-fx-background-color: #111111; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 800; -fx-background-radius: 999; -fx-min-width: 36; -fx-min-height: 36; -fx-pref-width: 36; -fx-pref-height: 36; -fx-alignment: center;"/>
                <Label fx:id="userNameLabel" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #111111;"/>
                <Button fx:id="logoutButton" text="Logout" onAction="#handleLogout" style="-fx-background-color: #dc2626; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 8 16; -fx-background-radius: 6; -fx-cursor: hand;"/>
            </HBox>
        </HBox>
    </top>

    <!-- Main Content -->
    <center>
        <HBox spacing="20" style="-fx-padding: 20;">
            <!-- Left: Classes List -->
            <VBox spacing="16" HBox.hgrow="ALWAYS" style="-fx-min-width: 600;">
                <!-- Header -->
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <TextField fx:id="searchField" promptText="Search classes..." prefWidth="300" style="-fx-font-size: 13px; -fx-padding: 8 12; -fx-background-radius: 6; -fx-border-color: #e7e5e4; -fx-border-radius: 6;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="addClassBtn" text="+ Add Class" style="-fx-background-color: #111111; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 700; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>
                
                <Label fx:id="classSummaryLabel" text="Loading..." style="-fx-font-size: 12px; -fx-text-fill: #78716c;"/>

                <!-- Classes Table -->
                <TableView fx:id="classTable" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e7e5e4; -fx-border-radius: 12; -fx-border-width: 1;">
                    <columns>
                        <TableColumn fx:id="colClassName" text="Class Name" prefWidth="200"/>
                        <TableColumn fx:id="colTeachers" text="Teachers" prefWidth="120"/>
                        <TableColumn fx:id="colStudents" text="Students" prefWidth="120"/>
                        <TableColumn fx:id="colCreatedDate" text="Created" prefWidth="100"/>
                        <TableColumn fx:id="colActions" text="Actions" prefWidth="140"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- Right: Class Details -->
            <VBox fx:id="detailsPane" spacing="16" style="-fx-min-width: 400; -fx-max-width: 450; -fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e7e5e4; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 20;">
                <!-- Header -->
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label fx:id="detailsClassName" text="Class Name" style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #111111;"/>
                        <HBox spacing="12">
                            <Label fx:id="detailsTeacherCount" text="0 teachers" style="-fx-font-size: 12px; -fx-text-fill: #78716c;"/>
                            <Label text="•" style="-fx-font-size: 12px; -fx-text-fill: #78716c;"/>
                            <Label fx:id="detailsStudentCount" text="0 students" style="-fx-font-size: 12px; -fx-text-fill: #78716c;"/>
                        </HBox>
                    </VBox>
                    <Button fx:id="closeDetailsBtn" text="✕" style="-fx-background-color: #f5f5f4; -fx-text-fill: #78716c; -fx-font-size: 16px; -fx-font-weight: 700; -fx-padding: 4 10; -fx-background-radius: 6; -fx-cursor: hand;"/>
                </HBox>

                <!-- Actions -->
                <HBox spacing="8">
                    <Button fx:id="editClassNameBtn" text="Edit Name" style="-fx-background-color: #f97316; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: 600; -fx-padding: 6 14; -fx-background-radius: 6; -fx-cursor: hand;"/>
                    <Button fx:id="deleteClassBtn" text="Delete Class" style="-fx-background-color: #dc2626; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: 600; -fx-padding: 6 14; -fx-background-radius: 6; -fx-cursor: hand;"/>
                </HBox>

                <Separator/>

                <!-- Teachers Section -->
                <VBox spacing="12">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="Assigned Teachers" style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #111111;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="addTeacherBtn" text="+ Add" style="-fx-background-color: #111111; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: 600; -fx-padding: 4 12; -fx-background-radius: 4; -fx-cursor: hand;"/>
                    </HBox>
                    
                    <TableView fx:id="teachersTable" prefHeight="180" style="-fx-background-color: #f9f9f9; -fx-background-radius: 8; -fx-border-color: #e7e5e4; -fx-border-radius: 8; -fx-border-width: 1;">
                        <columns>
                            <TableColumn fx:id="colTeacherName" text="Teacher Name" prefWidth="240"/>
                            <TableColumn fx:id="colTeacherActions" text="" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>

                <Separator/>

                <!-- Students Section -->
                <VBox spacing="12" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="Enrolled Students" style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #111111;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="addStudentBtn" text="+ Add" style="-fx-background-color: #111111; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: 600; -fx-padding: 4 12; -fx-background-radius: 4; -fx-cursor: hand;"/>
                    </HBox>
                    
                    <TableView fx:id="studentsTable" VBox.vgrow="ALWAYS" style="-fx-background-color: #f9f9f9; -fx-background-radius: 8; -fx-border-color: #e7e5e4; -fx-border-radius: 8; -fx-border-width: 1;">
                        <columns>
                            <TableColumn fx:id="colStudentName" text="Student Name" prefWidth="240"/>
                            <TableColumn fx:id="colStudentActions" text="" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>
