<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="860.0" prefWidth="1280.0" stylesheets="@styles.css"
            style="-fx-background-color: #f8f8f7; -fx-font-family: 'Segoe UI';"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hamroschool.controller.StudentDashboardController">

    <left>
        <VBox prefWidth="220.0" spacing="18.0"
              style="-fx-background-color: #fbfbfa; -fx-border-color: #eceae6; -fx-border-width: 0 1 0 0;">
            <padding><Insets bottom="24.0" left="20.0" right="16.0" top="18.0" /></padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <ImageView fitHeight="38.0" fitWidth="38.0" preserveRatio="true">
                            <image><Image url="@assets/logo.png" /></image>
                        </ImageView>
                        <VBox spacing="2.0">
                            <children>
                                <Label style="-fx-text-fill: #161616; -fx-font-size: 16px; -fx-font-weight: 800;" text="Hamro School" />
                                <Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 12px;" text="Student Portal" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="8.0">
                    <children>
                        <Button fx:id="navDashboardBtn" alignment="CENTER_LEFT" graphicTextGap="12.0"
                                onAction="#handleNavDashboard" prefHeight="40.0" maxWidth="Infinity"
                                style="-fx-background-color: #111111; -fx-background-radius: 8; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: 700; -fx-padding: 10 14 10 14; -fx-cursor: hand;"
                                text="Dashboard">
                            <graphic><ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                <image><Image url="@assets/admin/aside/dashboard.png" /></image>
                            </ImageView></graphic>
                        </Button>
                        <Button fx:id="navMarksBtn" alignment="CENTER_LEFT" graphicTextGap="12.0"
                                onAction="#handleNavMarks" prefHeight="40.0" maxWidth="Infinity"
                                style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14; -fx-cursor: hand;"
                                text="My Marks">
                            <graphic><ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                <image><Image url="@assets/admin/aside/account.png" /></image>
                            </ImageView></graphic>
                        </Button>
                        <Button fx:id="navAttendanceBtn" alignment="CENTER_LEFT" graphicTextGap="12.0"
                                onAction="#handleNavAttendance" prefHeight="40.0" maxWidth="Infinity"
                                style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14; -fx-cursor: hand;"
                                text="Attendance">
                            <graphic><ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                <image><Image url="@assets/admin/aside/student.png" /></image>
                            </ImageView></graphic>
                        </Button>
                    </children>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <Button fx:id="logoutButton" alignment="CENTER_LEFT" graphicTextGap="12.0"
                        onAction="#handleLogout" prefHeight="40.0" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #272727; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 10 14 10 14; -fx-cursor: hand;"
                        text="Logout">
                    <graphic><ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                        <image><Image url="@assets/admin/aside/logout.png" /></image>
                    </ImageView></graphic>
                </Button>
            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <content>
                <VBox spacing="24.0" style="-fx-padding: 28 32 32 32; -fx-background-color: transparent;">
                    <children>

                        <HBox alignment="CENTER_LEFT" spacing="16.0">
                            <children>
                                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="welcomeLabel"
                                               style="-fx-font-size: 30px; -fx-font-weight: 800; -fx-text-fill: #171717;"
                                               text="Hello!" />
                                        <Label fx:id="welcomeSubLabel"
                                               style="-fx-font-size: 14px; -fx-text-fill: #8a8a8a;"
                                               text="Here's your academic summary for today." />
                                    </children>
                                </VBox>
                                <HBox alignment="CENTER_LEFT" spacing="10.0"
                                      style="-fx-background-color: white; -fx-background-radius: 999; -fx-border-color: #ebe9e4; -fx-border-radius: 999; -fx-padding: 8 14 8 10;">
                                    <children>
                                        <Label fx:id="userInitialsLabel"
                                               style="-fx-background-color: #1d1d1d; -fx-background-radius: 999; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: 800; -fx-min-width: 28; -fx-min-height: 28; -fx-pref-width: 28; -fx-pref-height: 28; -fx-alignment: center;"
                                               text="ST" />
                                        <Label fx:id="userNameLabel"
                                               style="-fx-text-fill: #1f1f1f; -fx-font-size: 13px; -fx-font-weight: 700;"
                                               text="student" />
                                    </children>
                                </HBox>
                            </children>
                        </HBox>

                        <HBox fx:id="dashboardPane" spacing="18.0">
                            <children>
                                <VBox prefWidth="200.0" spacing="8.0"
                                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e8e6e1; -fx-border-radius: 14; -fx-padding: 18; -fx-effect: dropshadow(gaussian,rgba(15,23,42,0.07),14,0.12,0,3);">
                                    <children>
                                        <Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 13px;" text="Subjects" />
                                        <Label fx:id="statSubjectsLabel" style="-fx-text-fill: #171717; -fx-font-size: 30px; -fx-font-weight: 800;" text="—" />
                                    </children>
                                </VBox>
                                <VBox prefWidth="200.0" spacing="8.0"
                                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e8e6e1; -fx-border-radius: 14; -fx-padding: 18; -fx-effect: dropshadow(gaussian,rgba(15,23,42,0.07),14,0.12,0,3);">
                                    <children>
                                        <Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 13px;" text="Avg Score" />
                                        <Label fx:id="statAvgLabel" style="-fx-text-fill: #f97316; -fx-font-size: 30px; -fx-font-weight: 800;" text="—" />
                                    </children>
                                </VBox>
                                <VBox prefWidth="200.0" spacing="8.0"
                                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e8e6e1; -fx-border-radius: 14; -fx-padding: 18; -fx-effect: dropshadow(gaussian,rgba(15,23,42,0.07),14,0.12,0,3);">
                                    <children>
                                        <Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 13px;" text="Attendance" />
                                        <Label fx:id="statAttLabel" style="-fx-text-fill: #16a34a; -fx-font-size: 30px; -fx-font-weight: 800;" text="—" />
                                    </children>
                                </VBox>
                                <VBox prefWidth="200.0" spacing="8.0"
                                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #e8e6e1; -fx-border-radius: 14; -fx-padding: 18; -fx-effect: dropshadow(gaussian,rgba(15,23,42,0.07),14,0.12,0,3);">
                                    <children>
                                        <Label style="-fx-text-fill: #8a8a8a; -fx-font-size: 13px;" text="Overall Grade" />
                                        <Label fx:id="statGradeLabel" style="-fx-text-fill: #2563eb; -fx-font-size: 30px; -fx-font-weight: 800;" text="—" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <StackPane VBox.vgrow="ALWAYS">
                            <children>

                                <VBox fx:id="marksPane" spacing="14.0"
                                      style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #e8e6e1; -fx-border-radius: 16; -fx-padding: 22; -fx-effect: dropshadow(gaussian,rgba(15,23,42,0.07),14,0.12,0,3);">
                                    <children>
                                        <Label style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #171717;" text="My Marks" />
                                        <Label style="-fx-font-size: 13px; -fx-text-fill: #8a8a8a;" text="All recorded marks across subjects" />
                                        <TableView fx:id="marksTable" VBox.vgrow="ALWAYS" prefHeight="420.0">
                                            <columns>
                                                <TableColumn fx:id="mColSubject"  prefWidth="220.0" text="Subject" />
                                                <TableColumn fx:id="mColTeacher"  prefWidth="180.0" text="Teacher" />
                                                <TableColumn fx:id="mColExam"     prefWidth="130.0" text="Exam Type" />
                                                <TableColumn fx:id="mColScore"    prefWidth="120.0" text="Score" />
                                                <TableColumn fx:id="mColGrade"    prefWidth="90.0"  text="Grade" />
                                                <TableColumn fx:id="mColRemarks"  prefWidth="200.0" text="Remarks" />
                                            </columns>
                                        </TableView>
                                        <Label fx:id="marksSummaryLabel" style="-fx-text-fill: #8a8a8a; -fx-font-size: 13px;" text="No marks yet." />
                                    </children>
                                </VBox>

                                <VBox fx:id="attendancePane" spacing="14.0" visible="false" managed="false"
                                      style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #e8e6e1; -fx-border-radius: 16; -fx-padding: 22; -fx-effect: dropshadow(gaussian,rgba(15,23,42,0.07),14,0.12,0,3);">
                                    <children>
                                        <Label style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #171717;" text="My Attendance" />
                                        <Label style="-fx-font-size: 13px; -fx-text-fill: #8a8a8a;" text="Attendance percentage per subject" />
                                        <TableView fx:id="attTable" VBox.vgrow="ALWAYS" prefHeight="420.0">
                                            <columns>
                                                <TableColumn fx:id="aColSubject" prefWidth="260.0" text="Subject" />
                                                <TableColumn fx:id="aColTeacher" prefWidth="200.0" text="Teacher" />
                                                <TableColumn fx:id="aColPct"     prefWidth="160.0" text="Attendance %" />
                                                <TableColumn fx:id="aColStatus"  prefWidth="140.0" text="Status" />
                                            </columns>
                                        </TableView>
                                        <Label fx:id="attSummaryLabel" style="-fx-text-fill: #8a8a8a; -fx-font-size: 13px;" text="" />
                                    </children>
                                </VBox>

                            </children>
                        </StackPane>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
